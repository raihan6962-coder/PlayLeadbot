# ═══════════════════════════════════════════════════════════
# PlayLead Engine v2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env for local development.
# On Render: set these in the Environment tab of your service.
# All of these can also be set live in the dashboard Settings.
# ═══════════════════════════════════════════════════════════

# ── AI / Groq ────────────────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Google Apps Script — Sheet Integration ───────────────────
# Paste one or more Web App URLs (separate with newlines or commas).
# System auto-rotates if a URL hits its daily quota limit.
APPS_SCRIPT_WEB_URLS=https://script.google.com/macros/s/YOUR_SHEET_SCRIPT_ID/exec

# ── Google Apps Script — Email Sender ────────────────────────
# This is the Apps Script deployment that calls GmailApp.sendEmail()
EMAIL_SCRIPT_URL=https://script.google.com/macros/s/YOUR_EMAIL_SCRIPT_ID/exec

# ── Sender Identity ───────────────────────────────────────────
SENDER_NAME=Your Full Name
SENDER_COMPANY=Your Company Name

# ── Sender Alias (optional) ───────────────────────────────────
# Must be configured in Gmail → Settings → "Send mail as"
# Leave blank to send from primary Gmail account
SENDER_ALIAS=outreach@yourdomain.com

# ── Automation Behaviour ──────────────────────────────────────
# Options: normal | conservative | aggressive
SEND_PROFILE=normal

# Default target if not set from dashboard
TARGET_LEADS=300

# ── Spam Word Filter (optional) ───────────────────────────────
# Comma or newline separated. AI will replace these before sending.
SPAM_WORDS=guaranteed,act now,limited time offer,click here
